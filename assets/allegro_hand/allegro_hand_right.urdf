<?xml version="1.0" ?>
<!-- Allegro Hand Right V4 - Corrected URDF for Isaac Sim
     Based on official Allegro Hand V4 kinematics (Wonik Robotics)
     16 DOF: 4 fingers x 4 joints
     Right hand convention: palm faces -Y, fingers extend along +Z
     Finger order: Index(0-3), Middle(4-7), Ring(8-11), Thumb(12-15) -->
<robot name="allegro_hand_right">

  <!-- ============ Materials ============ -->
  <material name="palm_mat"><color rgba="0.2 0.2 0.2 1"/></material>
  <material name="finger_mat"><color rgba="0.5 0.5 0.55 1"/></material>
  <material name="tip_mat"><color rgba="0.85 0.6 0.45 1"/></material>

  <!-- ============ BASE LINK (Palm) ============ -->
  <!-- Palm oriented: width along X, thin along Y, height along Z -->
  <link name="base_link">
    <visual>
      <origin xyz="0 0 0.04" rpy="0 0 0"/>
      <geometry><box size="0.092 0.012 0.09"/></geometry>
      <material name="palm_mat"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.04" rpy="0 0 0"/>
      <geometry><box size="0.092 0.012 0.09"/></geometry>
    </collision>
    <inertial>
      <mass value="0.4"/>
      <inertia ixx="1e-3" ixy="0" ixz="0" iyy="1e-3" iyz="0" izz="1e-3"/>
    </inertial>
  </link>

  <!-- ============================================================ -->
  <!-- INDEX FINGER (joints 0-3) — rightmost from palm front view   -->
  <!-- ============================================================ -->
  <link name="index_link_0">
    <visual><origin xyz="0 0 0.027"/><geometry><cylinder radius="0.007" length="0.054"/></geometry><material name="finger_mat"/></visual>
    <collision><origin xyz="0 0 0.027"/><geometry><cylinder radius="0.007" length="0.054"/></geometry></collision>
    <inertial><mass value="0.044"/><inertia ixx="1e-5" ixy="0" ixz="0" iyy="1e-5" iyz="0" izz="1e-6"/></inertial>
  </link>
  <joint name="joint_0" type="revolute">
    <parent link="base_link"/><child link="index_link_0"/>
    <origin xyz="0.0377 -0.007 0.0584" rpy="0.08 -0.28 0"/>
    <axis xyz="1 0 0"/>
    <limit lower="-0.47" upper="0.47" effort="0.7" velocity="7.0"/>
    <dynamics damping="0.01" friction="0.001"/>
  </joint>

  <link name="index_link_1">
    <visual><origin xyz="0 0 0.027"/><geometry><cylinder radius="0.0065" length="0.054"/></geometry><material name="finger_mat"/></visual>
    <collision><origin xyz="0 0 0.027"/><geometry><cylinder radius="0.0065" length="0.054"/></geometry></collision>
    <inertial><mass value="0.044"/><inertia ixx="1e-5" ixy="0" ixz="0" iyy="1e-5" iyz="0" izz="1e-6"/></inertial>
  </link>
  <joint name="joint_1" type="revolute">
    <parent link="index_link_0"/><child link="index_link_1"/>
    <origin xyz="0 0 0.054"/>
    <axis xyz="0 0 1"/>
    <limit lower="-0.196" upper="1.61" effort="0.7" velocity="7.0"/>
    <dynamics damping="0.01" friction="0.001"/>
  </joint>

  <link name="index_link_2">
    <visual><origin xyz="0 0 0.011"/><geometry><cylinder radius="0.006" length="0.022"/></geometry><material name="finger_mat"/></visual>
    <collision><origin xyz="0 0 0.011"/><geometry><cylinder radius="0.006" length="0.022"/></geometry></collision>
    <inertial><mass value="0.034"/><inertia ixx="5e-6" ixy="0" ixz="0" iyy="5e-6" iyz="0" izz="5e-7"/></inertial>
  </link>
  <joint name="joint_2" type="revolute">
    <parent link="index_link_1"/><child link="index_link_2"/>
    <origin xyz="0 0 0.054"/>
    <axis xyz="0 0 1"/>
    <limit lower="-0.174" upper="1.709" effort="0.7" velocity="7.0"/>
    <dynamics damping="0.01" friction="0.001"/>
  </joint>

  <link name="index_link_3">
    <visual><origin xyz="0 0 0.012"/><geometry><sphere radius="0.009"/></geometry><material name="tip_mat"/></visual>
    <collision><origin xyz="0 0 0.012"/><geometry><sphere radius="0.009"/></geometry></collision>
    <inertial><mass value="0.022"/><inertia ixx="3e-6" ixy="0" ixz="0" iyy="3e-6" iyz="0" izz="3e-7"/></inertial>
  </link>
  <joint name="joint_3" type="revolute">
    <parent link="index_link_2"/><child link="index_link_3"/>
    <origin xyz="0 0 0.022"/>
    <axis xyz="0 0 1"/>
    <limit lower="-0.227" upper="1.618" effort="0.7" velocity="7.0"/>
    <dynamics damping="0.01" friction="0.001"/>
  </joint>

  <!-- ============================================================ -->
  <!-- MIDDLE FINGER (joints 4-7) — center finger                   -->
  <!-- ============================================================ -->
  <link name="middle_link_0">
    <visual><origin xyz="0 0 0.027"/><geometry><cylinder radius="0.007" length="0.054"/></geometry><material name="finger_mat"/></visual>
    <collision><origin xyz="0 0 0.027"/><geometry><cylinder radius="0.007" length="0.054"/></geometry></collision>
    <inertial><mass value="0.044"/><inertia ixx="1e-5" ixy="0" ixz="0" iyy="1e-5" iyz="0" izz="1e-6"/></inertial>
  </link>
  <joint name="joint_4" type="revolute">
    <parent link="base_link"/><child link="middle_link_0"/>
    <origin xyz="0.012 -0.007 0.0824" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <limit lower="-0.47" upper="0.47" effort="0.7" velocity="7.0"/>
    <dynamics damping="0.01" friction="0.001"/>
  </joint>

  <link name="middle_link_1">
    <visual><origin xyz="0 0 0.027"/><geometry><cylinder radius="0.0065" length="0.054"/></geometry><material name="finger_mat"/></visual>
    <collision><origin xyz="0 0 0.027"/><geometry><cylinder radius="0.0065" length="0.054"/></geometry></collision>
    <inertial><mass value="0.044"/><inertia ixx="1e-5" ixy="0" ixz="0" iyy="1e-5" iyz="0" izz="1e-6"/></inertial>
  </link>
  <joint name="joint_5" type="revolute">
    <parent link="middle_link_0"/><child link="middle_link_1"/>
    <origin xyz="0 0 0.054"/>
    <axis xyz="0 0 1"/>
    <limit lower="-0.196" upper="1.61" effort="0.7" velocity="7.0"/>
    <dynamics damping="0.01" friction="0.001"/>
  </joint>

  <link name="middle_link_2">
    <visual><origin xyz="0 0 0.011"/><geometry><cylinder radius="0.006" length="0.022"/></geometry><material name="finger_mat"/></visual>
    <collision><origin xyz="0 0 0.011"/><geometry><cylinder radius="0.006" length="0.022"/></geometry></collision>
    <inertial><mass value="0.034"/><inertia ixx="5e-6" ixy="0" ixz="0" iyy="5e-6" iyz="0" izz="5e-7"/></inertial>
  </link>
  <joint name="joint_6" type="revolute">
    <parent link="middle_link_1"/><child link="middle_link_2"/>
    <origin xyz="0 0 0.054"/>
    <axis xyz="0 0 1"/>
    <limit lower="-0.174" upper="1.709" effort="0.7" velocity="7.0"/>
    <dynamics damping="0.01" friction="0.001"/>
  </joint>

  <link name="middle_link_3">
    <visual><origin xyz="0 0 0.012"/><geometry><sphere radius="0.009"/></geometry><material name="tip_mat"/></visual>
    <collision><origin xyz="0 0 0.012"/><geometry><sphere radius="0.009"/></geometry></collision>
    <inertial><mass value="0.022"/><inertia ixx="3e-6" ixy="0" ixz="0" iyy="3e-6" iyz="0" izz="3e-7"/></inertial>
  </link>
  <joint name="joint_7" type="revolute">
    <parent link="middle_link_2"/><child link="middle_link_3"/>
    <origin xyz="0 0 0.022"/>
    <axis xyz="0 0 1"/>
    <limit lower="-0.227" upper="1.618" effort="0.7" velocity="7.0"/>
    <dynamics damping="0.01" friction="0.001"/>
  </joint>

  <!-- ============================================================ -->
  <!-- RING/PINKY FINGER (joints 8-11) — leftmost from front view   -->
  <!-- ============================================================ -->
  <link name="ring_link_0">
    <visual><origin xyz="0 0 0.027"/><geometry><cylinder radius="0.007" length="0.054"/></geometry><material name="finger_mat"/></visual>
    <collision><origin xyz="0 0 0.027"/><geometry><cylinder radius="0.007" length="0.054"/></geometry></collision>
    <inertial><mass value="0.044"/><inertia ixx="1e-5" ixy="0" ixz="0" iyy="1e-5" iyz="0" izz="1e-6"/></inertial>
  </link>
  <joint name="joint_8" type="revolute">
    <parent link="base_link"/><child link="ring_link_0"/>
    <origin xyz="-0.0177 -0.007 0.0584" rpy="-0.08 0.28 0"/>
    <axis xyz="1 0 0"/>
    <limit lower="-0.47" upper="0.47" effort="0.7" velocity="7.0"/>
    <dynamics damping="0.01" friction="0.001"/>
  </joint>

  <link name="ring_link_1">
    <visual><origin xyz="0 0 0.027"/><geometry><cylinder radius="0.0065" length="0.054"/></geometry><material name="finger_mat"/></visual>
    <collision><origin xyz="0 0 0.027"/><geometry><cylinder radius="0.0065" length="0.054"/></geometry></collision>
    <inertial><mass value="0.044"/><inertia ixx="1e-5" ixy="0" ixz="0" iyy="1e-5" iyz="0" izz="1e-6"/></inertial>
  </link>
  <joint name="joint_9" type="revolute">
    <parent link="ring_link_0"/><child link="ring_link_1"/>
    <origin xyz="0 0 0.054"/>
    <axis xyz="0 0 1"/>
    <limit lower="-0.196" upper="1.61" effort="0.7" velocity="7.0"/>
    <dynamics damping="0.01" friction="0.001"/>
  </joint>

  <link name="ring_link_2">
    <visual><origin xyz="0 0 0.011"/><geometry><cylinder radius="0.006" length="0.022"/></geometry><material name="finger_mat"/></visual>
    <collision><origin xyz="0 0 0.011"/><geometry><cylinder radius="0.006" length="0.022"/></geometry></collision>
    <inertial><mass value="0.034"/><inertia ixx="5e-6" ixy="0" ixz="0" iyy="5e-6" iyz="0" izz="5e-7"/></inertial>
  </link>
  <joint name="joint_10" type="revolute">
    <parent link="ring_link_1"/><child link="ring_link_2"/>
    <origin xyz="0 0 0.054"/>
    <axis xyz="0 0 1"/>
    <limit lower="-0.174" upper="1.709" effort="0.7" velocity="7.0"/>
    <dynamics damping="0.01" friction="0.001"/>
  </joint>

  <link name="ring_link_3">
    <visual><origin xyz="0 0 0.012"/><geometry><sphere radius="0.009"/></geometry><material name="tip_mat"/></visual>
    <collision><origin xyz="0 0 0.012"/><geometry><sphere radius="0.009"/></geometry></collision>
    <inertial><mass value="0.022"/><inertia ixx="3e-6" ixy="0" ixz="0" iyy="3e-6" iyz="0" izz="3e-7"/></inertial>
  </link>
  <joint name="joint_11" type="revolute">
    <parent link="ring_link_2"/><child link="ring_link_3"/>
    <origin xyz="0 0 0.022"/>
    <axis xyz="0 0 1"/>
    <limit lower="-0.227" upper="1.618" effort="0.7" velocity="7.0"/>
    <dynamics damping="0.01" friction="0.001"/>
  </joint>

  <!-- ============================================================ -->
  <!-- THUMB (joints 12-15) — on the palm side, opposing fingers     -->
  <!-- Thumb base is at bottom-right of palm, rotated to oppose      -->
  <!-- ============================================================ -->
  <link name="thumb_link_0">
    <visual><origin xyz="0 0 0.0295"/><geometry><cylinder radius="0.009" length="0.059"/></geometry><material name="finger_mat"/></visual>
    <collision><origin xyz="0 0 0.0295"/><geometry><cylinder radius="0.009" length="0.059"/></geometry></collision>
    <inertial><mass value="0.055"/><inertia ixx="1e-5" ixy="0" ixz="0" iyy="1e-5" iyz="0" izz="1e-6"/></inertial>
  </link>
  <joint name="joint_12" type="revolute">
    <parent link="base_link"/><child link="thumb_link_0"/>
    <origin xyz="-0.0182 -0.019 -0.045" rpy="3.14159 1.34 -0.26"/>
    <axis xyz="-1 0 0"/>
    <limit lower="0.263" upper="1.396" effort="0.7" velocity="7.0"/>
    <dynamics damping="0.01" friction="0.001"/>
  </joint>

  <link name="thumb_link_1">
    <visual><origin xyz="0 0 0.027"/><geometry><cylinder radius="0.008" length="0.054"/></geometry><material name="finger_mat"/></visual>
    <collision><origin xyz="0 0 0.027"/><geometry><cylinder radius="0.008" length="0.054"/></geometry></collision>
    <inertial><mass value="0.048"/><inertia ixx="1e-5" ixy="0" ixz="0" iyy="1e-5" iyz="0" izz="1e-6"/></inertial>
  </link>
  <joint name="joint_13" type="revolute">
    <parent link="thumb_link_0"/><child link="thumb_link_1"/>
    <origin xyz="0 0 0.059"/>
    <axis xyz="0 0 -1"/>
    <limit lower="-0.105" upper="1.163" effort="0.7" velocity="7.0"/>
    <dynamics damping="0.01" friction="0.001"/>
  </joint>

  <link name="thumb_link_2">
    <visual><origin xyz="0 0 0.0195"/><geometry><cylinder radius="0.007" length="0.039"/></geometry><material name="finger_mat"/></visual>
    <collision><origin xyz="0 0 0.0195"/><geometry><cylinder radius="0.007" length="0.039"/></geometry></collision>
    <inertial><mass value="0.04"/><inertia ixx="5e-6" ixy="0" ixz="0" iyy="5e-6" iyz="0" izz="5e-7"/></inertial>
  </link>
  <joint name="joint_14" type="revolute">
    <parent link="thumb_link_1"/><child link="thumb_link_2"/>
    <origin xyz="0 0 0.054"/>
    <axis xyz="0 0 1"/>
    <limit lower="-0.189" upper="1.644" effort="0.7" velocity="7.0"/>
    <dynamics damping="0.01" friction="0.001"/>
  </joint>

  <link name="thumb_link_3">
    <visual><origin xyz="0 0 0.012"/><geometry><sphere radius="0.011"/></geometry><material name="tip_mat"/></visual>
    <collision><origin xyz="0 0 0.012"/><geometry><sphere radius="0.011"/></geometry></collision>
    <inertial><mass value="0.025"/><inertia ixx="3e-6" ixy="0" ixz="0" iyy="3e-6" iyz="0" izz="3e-7"/></inertial>
  </link>
  <joint name="joint_15" type="revolute">
    <parent link="thumb_link_2"/><child link="thumb_link_3"/>
    <origin xyz="0 0 0.039"/>
    <axis xyz="0 0 1"/>
    <limit lower="-0.162" upper="1.719" effort="0.7" velocity="7.0"/>
    <dynamics damping="0.01" friction="0.001"/>
  </joint>

</robot>
